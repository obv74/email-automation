# Application
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite:///./data/email_agent.db

# JWT (access tokens for web app)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Default tenant (legacy bootstrap)
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Moving Company

# Ollama (local LLM) — default extract engine
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_READ_TIMEOUT_SECONDS=600
OLLAMA_NUM_PREDICT=512
# Extract page: keep these low on weak VPS CPUs (accuracy via enrich + short prompt)
OLLAMA_EXTRACT_NUM_PREDICT=400
OLLAMA_EXTRACT_MAX_CHARS=3500

# Optional cloud extract — controlled only via server .env (no UI toggle)
# LLM_ENGINE=local
# CLOUD_LLM_API_KEY=
# CLOUD_LLM_BASE_URL=https://api.openai.com/v1
# CLOUD_LLM_MODEL=gpt-4o-mini
# CLOUD_LLM_TIMEOUT_SECONDS=120

CLASSIFY_ENABLED=true

# Google OAuth — redirect URI stays on VPS API (not Vercel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Google Sheets pricing (fallback if company has no sheet)
PRICING_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=

REPLY_MODE=draft

SCHEDULER_ENABLED=true
POLL_GMAIL_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_MINUTES=60
FOLLOWUP_CHECK_INTERVAL_MINUTES=60

FOLLOWUP_WAIT_DAYS=3
FOLLOWUP_MAX_ATTEMPTS=2
REMINDER_DAYS=3,1

RULES_FILE=config/rules.yaml
OAUTH_ALLOW_INSECURE_TRANSPORT=true
