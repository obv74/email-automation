# Application
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./data/email_agent.db

# Default tenant (v1 single-company mode)
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Moving Company

# Ollama (local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Google OAuth (Gmail + Sheets) — create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Google Sheets pricing
PRICING_SHEET_ID=
# Path to service account JSON (optional; if empty, uses OAuth token for Sheets)
GOOGLE_SERVICE_ACCOUNT_FILE=

# Reply behavior: draft | send
REPLY_MODE=draft

# Scheduler (cron-style, server local time)
SCHEDULER_ENABLED=true
POLL_GMAIL_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_MINUTES=60
FOLLOWUP_CHECK_INTERVAL_MINUTES=60

# Lead follow-up: resend if no reply after N days, max attempts
FOLLOWUP_WAIT_DAYS=3
FOLLOWUP_MAX_ATTEMPTS=2

# Confirmation reminders (days before move_date)
REMINDER_DAYS=2,1

# Rules file (YAML) for stock replies
RULES_FILE=config/rules.yaml
